-- Sistema anti-kick e anti-detecção (obfuscation básico)
local function AntiCheatBypass()
    -- Renomear variáveis críticas (confunde scanners básicos)
    local FakeEnv = {
        checkcaller = function() return true end,
        hookfunction = function(f, newf) return f end,
        newcclosure = function(f) return f end,
        clonefunction = function(f) return f end
    }
    
    -- Interceptar chamadas de detecção comum
    local OldNamecall
    OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local Method = getnamecallmethod()
        
        -- Bypass para detecções comuns de cheats no Roblox
        if Method == "Kick" or Method == "kick" then
            return nil -- Ignorar kicks
        elseif Method == "FindFirstChild" and tostring(self):lower():find("cheat") then
            return nil -- Esconder objetos relacionados a cheat
        elseif Method == "GetChildren" and tostring(self) == "CoreGui" then
            local Children = OldNamecall(self, ...)
            return Children -- Não modificar para evitar suspeitas
        end
        
        return OldNamecall(self, ...)
    end)
    
    -- Ocultar o script no ambiente de execução
    pcall(function()
        script.Parent = nil
        script:Destroy()
    end)
end

